{
    auto_https off
    admin off

    # Plugin mholt/caddy-ratelimit nu e directive standard;
    # spunem Caddy unde să-l plaseze în lanțul de handlers.
    order rate_limit before reverse_proxy

    log {
        output stdout
        format json
    }
}

:8080 {
    # === Health check public ===
    # Fără filter IP, fără auth, fără rate limit — accesibil de oriunde pentru monitoring extern.
    # Plasat primul ca să răspundă chiar dacă restul cer auth+IP allowlist.
    handle /caddy-health {
        respond "ok" 200
    }

    # === IP Allowlist (Pas 4) ===
    # IP filter ÎNAINTE de Bearer auth: ascundem existența auth-ului față de IP-uri neautorizate
    # (primesc 403 fără să afle că ar putea încerca cu un Bearer token).
    @from_disallowed_ip not remote_ip {$CLERIQ_ALLOWED_IPS}
    handle @from_disallowed_ip {
        respond "Forbidden" 403
    }

    # === Rate limit per Bearer token (Pas 5) ===
    # Cheia = header-ul complet "Bearer <key>". Astfel:
    # - O cheie validă are propriul bucket (10 req/min — nu împărtășește cu altcineva).
    # - O cheie greșită are bucket separat (atacatorul nu poate consuma quota celei valide
    #   și nici nu poate brute-force, e tot limitat la 10/min).
    # @not_health = defense in depth — /caddy-health e deja interceptat mai sus de `handle`,
    # dar matcher-ul explicit elimină orice ambiguitate de ordering în Caddy.
    @not_health not path /caddy-health
    rate_limit @not_health {
        zone bearer_zone {
            key {http.request.header.authorization}
            events 10
            window 1m
        }
    }

    # === Bearer auth (Pas 3) ===
    # Defense in depth: dacă WHISPER_API_KEY_BACKUP nu e setat, matcher-ul @key_backup
    # s-ar expanda la `Bearer ` (gol) — interceptat aici primul.
    @empty_bearer header Authorization "Bearer "
    handle @empty_bearer {
        respond "Unauthorized" 401
    }

    # Cheia primară (obligatorie — entrypoint.sh refuză să pornească fără ea).
    @key_primary header Authorization "Bearer {$WHISPER_API_KEY}"
    handle @key_primary {
        reverse_proxy 127.0.0.1:9000 {
            transport http {
                read_timeout 6h
                write_timeout 6h
                dial_timeout 30s
            }
        }
    }

    # Cheia backup (opțională — pentru rotație fără downtime).
    @key_backup header Authorization "Bearer {$WHISPER_API_KEY_BACKUP}"
    handle @key_backup {
        reverse_proxy 127.0.0.1:9000 {
            transport http {
                read_timeout 6h
                write_timeout 6h
                dial_timeout 30s
            }
        }
    }

    # Fallback: Bearer lipsă, cheie greșită, etc. → 401.
    handle {
        respond "Unauthorized" 401
    }

    # Token redaction: header Authorization șters complet din log-uri.
    log {
        output stdout
        format filter {
            wrap json
            fields {
                request>headers>Authorization delete
            }
        }
    }
}
