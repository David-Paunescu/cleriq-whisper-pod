{
    auto_https off
    admin off

    log {
        output stdout
        format json
    }
}

:8080 {
    # === Health check public ===
    # În AFARA route block-ului → evaluat înainte de orice (rate limit, IP filter, auth).
    # Accesibil de oriunde pentru monitoring extern.
    handle /caddy-health {
        respond "ok" 200
    }

    # === IP Allowlist (Pas 4) ===
    # În AFARA route block-ului → 403 fast path înainte ca atacatorul să aibă șansa
    # să afle că există auth sau să consume quota rate-limit.
    @from_disallowed_ip not remote_ip {$CLERIQ_ALLOWED_IPS}
    handle @from_disallowed_ip {
        respond "Forbidden" 403
    }

    # === Restul logicii (rate limit + Bearer auth) ===
    # `route` block = ordine EXPLICITĂ declarată, fără inferență globală.
    # Plugin-ul rate_limit funcționează predictibil aici (decizie Pas 5).
    route {
        # === Rate limit per Bearer token (Pas 5) ===
        # Primul în route → declanșează 429 ÎNAINTE de orice match Bearer.
        # Cheia = header-ul complet "Bearer <key>":
        # - O cheie validă are propriul bucket (10 req/min — nu împărtășește cu altcineva).
        # - O cheie greșită are bucket separat (atacator nu poate consuma quota celei valide
        #   și nici nu poate brute-force, tot e limitat la 10/min).
        rate_limit {
            zone bearer_zone {
                key {http.request.header.authorization}
                events 10
                window 1m
            }
        }

        # === Bearer auth (Pas 3) ===
        # Defense in depth: dacă WHISPER_API_KEY_BACKUP nu e setat, matcher-ul @key_backup
        # s-ar expanda la `Bearer ` (gol) — interceptat aici primul.
        @empty_bearer header Authorization "Bearer "
        handle @empty_bearer {
            respond "Unauthorized" 401
        }

        # Cheia primară (obligatorie — entrypoint.sh refuză să pornească fără ea).
        @key_primary header Authorization "Bearer {$WHISPER_API_KEY}"
        handle @key_primary {
            reverse_proxy 127.0.0.1:9000 {
                transport http {
                    read_timeout 6h
                    write_timeout 6h
                    dial_timeout 30s
                }
            }
        }

        # Cheia backup (opțională — pentru rotație fără downtime).
        @key_backup header Authorization "Bearer {$WHISPER_API_KEY_BACKUP}"
        handle @key_backup {
            reverse_proxy 127.0.0.1:9000 {
                transport http {
                    read_timeout 6h
                    write_timeout 6h
                    dial_timeout 30s
                }
            }
        }

        # Fallback: Bearer lipsă, cheie greșită, etc. → 401.
        handle {
            respond "Unauthorized" 401
        }
    }

    # Token redaction: header Authorization șters complet din log-uri.
    log {
        output stdout
        format filter {
            wrap json
            fields {
                request>headers>Authorization delete
            }
        }
    }
}
