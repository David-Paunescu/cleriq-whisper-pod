{
    auto_https off
    admin off
    log {
        output stdout
        format json
    }
}

:8080 {
    # === Health check public ===
    # Fără filter IP, fără auth — accesibil de oriunde pentru monitoring extern.
    # Plasat primul ca să răspundă chiar dacă restul cer auth+IP allowlist.
    handle /caddy-health {
        respond "ok" 200
    }

    # === IP Allowlist (Pas 4) ===
    # CLERIQ_ALLOWED_IPS = listă IP-uri/CIDR separate prin spațiu.
    # entrypoint.sh setează default "0.0.0.0/0 ::/0" (allow all) dacă env var-ul lipsește.
    # Producție: setează env var la IP-ul fix al serverului Cleriq.
    # IP filter ÎNAINTE de Bearer auth: ascundem existența auth-ului față de IP-uri neautorizate
    # (primesc 403 fără să afle că ar putea încerca cu un Bearer token).
    @from_disallowed_ip not remote_ip {$CLERIQ_ALLOWED_IPS}
    handle @from_disallowed_ip {
        respond "Forbidden" 403
    }

    # === Bearer auth (Pas 3) ===
    # Defense in depth: dacă WHISPER_API_KEY_BACKUP nu e setat, matcher-ul @key_backup
    # s-ar expanda la `Bearer ` (gol) — interceptat aici primul.
    @empty_bearer header Authorization "Bearer "
    handle @empty_bearer {
        respond "Unauthorized" 401
    }

    # Cheia primară (obligatorie — entrypoint.sh refuză să pornească fără ea).
    @key_primary header Authorization "Bearer {$WHISPER_API_KEY}"
    handle @key_primary {
        reverse_proxy 127.0.0.1:9000 {
            transport http {
                read_timeout 6h
                write_timeout 6h
                dial_timeout 30s
            }
        }
    }

    # Cheia backup (opțională — pentru rotație fără downtime).
    @key_backup header Authorization "Bearer {$WHISPER_API_KEY_BACKUP}"
    handle @key_backup {
        reverse_proxy 127.0.0.1:9000 {
            transport http {
                read_timeout 6h
                write_timeout 6h
                dial_timeout 30s
            }
        }
    }

    # Fallback: Bearer lipsă, cheie greșită, etc. → 401.
    handle {
        respond "Unauthorized" 401
    }

    # Token redaction (Pas 6 implicit): header Authorization șters complet din log-uri.
    log {
        output stdout
        format filter {
            wrap json
            fields {
                request>headers>Authorization delete
            }
        }
    }
}
